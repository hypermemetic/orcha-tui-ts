    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
